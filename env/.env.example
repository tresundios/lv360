# ==========================================================================
# .env.example — Template for environment files
# Copy to .env.local / .env.dev / etc. and fill in values
# ==========================================================================

# --- Environment ---
ENVIRONMENT=local
DOCKER_IMAGE_TAG=local

# --- PostgreSQL ---
POSTGRES_DB=lamviec360
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:CHANGE_ME@postgres:5432/lamviec360

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# --- Frontend (VITE_ prefix required for Vite) ---
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=local

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Docker Hub ---
DOCKER_REGISTRY=docker.io
DOCKER_REPO_BACKEND=lamviec360-backend
DOCKER_REPO_FRONTEND=lamviec360-frontend
