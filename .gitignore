.coverage
htmlcov/

# --- Environment ---
.env
.env.*
!env/.env.example
env/.env.local
env/.env.dev
env/.env.qa
env/.env.uat
env/.env.prod

# --- Docker ---
*.log

# --- IDE ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS ---
.DS_Store
Thumbs.db

# --- Misc ---
*.local
